{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@cf/appointments/*": [
        "./src/features/appointments/*"
      ],
      "@cf/auth/*": [
        "./src/features/auth/*"
      ],
      "@cf/billing/*": [
        "./src/features/billing/*"
      ],
      "@cf/clinics/*": [
        "./src/features/clinics/*"
      ],
      "@cf/dependents/*": [
        "./src/features/dependents/*"
      ],
      "@cf/doctors/*": [
        "./src/features/doctors/*"
      ],
      "@cf/exams/*": [
        "./src/features/exams/*"
      ],
      "@cf/messaging/*": [
        "./src/features/messaging/*"
      ],
      "@cf/patients/*": [
        "./src/features/patients/*"
      ],
      "@cf/procedure-requests/*": [
        "./src/features/procedure-requests/*"
      ],
      "@cf/schedule/*": [
        "./src/features/schedule/*"
      ],
      "@cf/plans/*": [
        "./src/features/plans/*"
      ],
      "@cf/services/*": [
        "./src/features/services/*"
      ],
      "@cf/subscriptions/*": [
        "./src/features/subscriptions/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/lib/api/generated",
    "src/__tests__/**"
  ]
}
