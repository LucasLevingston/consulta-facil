  "components": {
    "schemas": {
      "CreateDoctorDTO": {
        "required": [
          "licenseNumber",
          "specialty"
        ],
        "type": "object",
        "properties": {
          "specialty": {
            "maxLength": 100,
            "minLength": 3,
            "type": "string"
          },
          "licenseNumber": {
            "maxLength": 50,
            "minLength": 5,
            "type": "string"
          }
        }
      },
      "DoctorResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "specialty": {
            "type": "string"
          },
          "licenseNumber": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          }
        }
      },
      "AppointmentResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "patientName": {
            "type": "string"
          },
          "patientId": {
            "type": "string"
          },
          "doctorName": {
            "type": "string"
          },
          "doctorId": {
            "type": "string"
          },
          "specialty": {
            "type": "string"
          },
          "scheduledAt": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "CONFIRMED",
              "CANCELED",
              "COMPLETED"
            ]
          },
          "cancellationReason": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
