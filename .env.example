# ─── CONSULTA FÁCIL WEB — Environment Variables ─────────────────────────────
# Copy to .env.local (dev) or set as environment variables in production.
# Never commit .env.local to git.
#
# DEV:  vars marked [DEV-REQUIRED] must be set to run locally.
# PROD: vars marked [PROD-REQUIRED] cause build/startup errors if missing.
#       vars marked [PROD-OPTIONAL] degrade gracefully when absent.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API Connection ───────────────────────────────────────────────────────────
# [DEV-REQUIRED] [PROD-REQUIRED]
# Base URL of the backend API (no trailing slash)
# Dev:  http://localhost:8080/v1
# Prod: https://api.yourdomain.com/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/v1

# ─── Grafana Faro — Real User Monitoring ─────────────────────────────────────
# [PROD-OPTIONAL] Leave blank locally — Faro is a no-op when not set.
# Get from: Grafana Cloud > Frontend Observability > New App > Collector URL
# Format: https://faro-collector-<region>.grafana.net/collect/<appId>
NEXT_PUBLIC_GRAFANA_FARO_URL=

# ─── App Metadata ────────────────────────────────────────────────────────────
# [PROD-OPTIONAL] Shown in Faro traces as the deployed version
NEXT_PUBLIC_APP_VERSION=1.0.0

